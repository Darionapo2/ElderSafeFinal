# ElderSafeFinal Environment Variables
# Copy this file to .env and fill in your values

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Get these from BotFather on Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=9876543210

# ── Firebase ────────────────────────────────────────────────────────────────
# Get this from Firebase Console → Realtime Database
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Firebase Service Account JSON (if using firebase-admin)
# Download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/serviceAccountKey.json

# ── Arduino Configuration (for bot.py) ───────────────────────────────────────
# IP and port where Arduino server is running
ARDUINO_IP=192.168.1.42
ARDUINO_PORT=8000
